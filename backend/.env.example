# Ranting chant Environment Variables
# Copy this file to .env.local for local development

# Security Keys (replace with actual keys in production)
E_PRIVATE_KEY=your_private_key_here
E_PRIVATE_PASSWORD=your_private_password_here
E_PUBLIC_KEY=your_public_key_here

# Database Configuration
# DATA_BACKEND controls which persistence layer is active:
#   json     — original JSON file store (default, safe for local dev)
#   supabase — PostgreSQL via Supabase REST/SQL
DATA_BACKEND=json

# Supabase Configuration (required when DATA_BACKEND=supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Legacy PostgreSQL Configuration (uncomment if using direct PostgreSQL)
# POSTGRES_DB=api_db
# POSTGRES_USER=api_user
# POSTGRES_PASSWORD=api_password
# DATABASE_URL=postgresql://api_user:api_password@postgres:5432/api_db

# Redis Configuration (uncomment if using Redis)
# REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=info

# API Configuration
API_TITLE=Ranting Chat restful API
API_VERSION=1.0.0
API_DESCRIPTION=backend for ranting chat application, built with FastAPI

# API keys
# API keys
GEMINI_API_KEY=api_key_here

ELEVENLABS_API_KEY=api_key_here

GRADIUM_API_KEY=api_key_here

TAVILY_API_KEY=api_key_here

RESEND_API_KEY=api_key_here

#Be sure to allow the proper Geo permissions on twilio, otherwise it will fail
TWILIO_ACCOUNT_SID=sid_here
TWILIO_AUTH_TOKEN=auth_token_here
TWILIO_VERIFIED_PHONE=number_here

#Preferable to use these
TWILIO_API_KEY_SID=api_key_sid_here
TWILIO_API_KEY_SECRET=api_key_secret_here

#Allow only Read to public repos
HF_API_KEY=api_key_here