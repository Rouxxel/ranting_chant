{
    "defaults":{
        "general_data_path":"src/data/general_data.json"
    },
    
    "logging":{
        "logging_level":"debug",
        "dir_name":"logs",
        "log_file_name":"ranting_chat_bcknd"
    },
    "email_validation":{
        "allowed_providers":["gmail","outlook","yahoo","hotmail","icloud","protonmail","aol","zoho","gmx","mail"],
        "allowed_tlds":["com", "org", "net", "co", "io", "edu", "gov"]
    },

    "llm_model":{
        "default_model":"gemini-3.1-flash-lite",
        "gemini_models":[
            "gemini-3.5-flash",
            "gemini-3.1-pro",
            "gemini-3.1-flash-lite",
            "gemini-3.1-flash",
            "gemini-3-flash",
            "gemini-2.5-pro",
            "gemini-2.5-flash-lite",
            "gemini-2.5-flash"
        ]
    },
    "voice_provider":{
        "default_provider":"elevenlabs",
        "gradium":{
            "api_base_url":"https://api.gradium.ai/api",
            "voice_id":"YTpq7expH9539ERJ",
            "tts_model":"default",
            "output_format":"wav"
        },
        "elevenlabs":{
            "stt":{
                "model_id":"scribe_v2",
                "language_code":"en",
                "diarize":true,
                "default_model":"base",
                "compute_type":"default",
                "device":"auto",
                "cpu_threads":1,
                "num_workers":1
            },
            "tts":{
                "model_id":"eleven_multilingual_v2",
                "output_format":"mp3_44100_128",
                "voice_id":"21m00Tcm4TlvDq8ikWAM"
            }
        }
    },

    "network":{
        "uvicorn_app_reference": "main:app",
        "server_port":8000,
        "host": "0.0.0.0",
        "reload": false,
        "workers": 1,
        "proxy_headers": true
    },

    "endpoints": {
        "root_directory_endpoint":{
            "request_limit":25,
            "unit_of_time_for_limit":"m",
            "endpoint_prefix": "",
            "endpoint_tag":"root",
            "endpoint_route": "/"
        },

        "tenants_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/tenants",
            "endpoint_tag": "Tenants",
            "list_route": "",
            "detail_route": "/{tenant_id}"
        },

        "properties_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/properties",
            "endpoint_tag": "Properties",
            "list_route": "",
            "detail_route": "/{property_id}"
        },

        "vendors_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/vendors",
            "endpoint_tag": "Vendors",
            "list_route": "",
            "by_service_route": "/by-service/{service}",
            "detail_route": "/{vendor_id}"
        },

        "managers_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/managers",
            "endpoint_tag": "Managers",
            "list_route": "",
            "detail_route": "/{manager_id}"
        },

        "owners_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/owners",
            "endpoint_tag": "Owners",
            "list_route": "",
            "detail_route": "/{owner_id}"
        },

        "requests_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/requests",
            "endpoint_tag": "Requests",
            "list_route": "",
            "detail_route": "/{request_id}",
            "notifications_route": "/{request_id}/notifications",
            "create_route": "",
            "update_route": "/{request_id}",
            "summary_route": "/{request_id}/summary"
        },

        "conversation_endpoint": {
            "request_limit": 30,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/conversation",
            "endpoint_tag": "Conversation",
            "start_route": "/start",
            "message_route": "/message",
            "history_route": "/{request_id}/history"
        },

        "mcp_endpoint": {
            "request_limit": 20,
            "unit_of_time_for_limit": "m",
            "endpoint_prefix": "/mcp",
            "endpoint_tag": "MCP",
            "tools_route": "/tools"
        }
    }
}

